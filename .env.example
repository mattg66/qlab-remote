# Copy this file and fill in values for your QLab setup:
#   - For `pnpm dev` / `pnpm start`, copy to .env.local
#   - For `docker compose`, copy to .env (Compose reads it for both
#     variable substitution in docker-compose.yml and the container's
#     runtime environment)
# Both .env.local and .env are gitignored.

# Hostname or IP address of the machine running QLab.
QLAB_HOST=127.0.0.1

# Port QLab listens for OSC on (Workspace Settings > Network > OSC Access).
# 53000 is QLab's default.
QLAB_PORT=53000

# Workspace passcode, if one is set (Workspace Settings > General).
# Leave blank if the workspace has no passcode.
QLAB_PASSCODE=

# Unique ID of the workspace to connect to. Find this in QLab via
# Window > Workspace Settings, or by sending /workspaces over OSC.
QLAB_WORKSPACE_ID=
